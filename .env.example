# ── REQUIRED ──────────────────────────────────────────────────────────────────
# Anthropic Claude API
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-...

# Tavily Search API (AI-optimized web search, primary source)
# Get from: https://app.tavily.com/  (free tier: 1,000 searches/month)
TAVILY_API_KEY=tvly-...

# ── OPTIONAL (strongly recommended for deeper research) ────────────────────────
# Exa Semantic Search API (neural/semantic, finds analyst reports and whitepapers)
# Get from: https://exa.ai/  (free tier: 1,000 searches/month)
EXA_API_KEY=...

# ── BACKEND CONFIG ────────────────────────────────────────────────────────────
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_RELOAD=true
ALLOWED_ORIGINS=http://localhost:3000

# ── RESEARCH CONFIG ───────────────────────────────────────────────────────────
# time_period_months is set per-request by the user (1-120 months)
# These are server-side defaults / limits
TAVILY_RESULTS_PER_QUERY=6
EXA_RESULTS_PER_QUERY=5
CONCURRENT_CLAUDE_CALLS=3
CLAUDE_MAX_TOKENS=3000

# ── FRONTEND (public, exposed to browser) ─────────────────────────────────────
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
